{
  "name": "@davepi/ui-core",
  "version": "0.3.0",
  "description": "Framework-agnostic schema registry, widget resolver, and JSON descriptors for davepi-ui — the schema-driven, agent-first admin UI framework for davepi backends.",
  "keywords": [
    "davepi",
    "davepi-ui",
    "admin",
    "schema-driven",
    "zod",
    "describe",
    "agent-first"
  ],
  "homepage": "https://github.com/projik/davepi-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projik/davepi-ui.git",
    "directory": "packages/ui-core"
  },
  "bugs": {
    "url": "https://github.com/projik/davepi-ui/issues"
  },
  "license": "MIT",
  "author": "David Baxter <dave@unlockedequity.com>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./describe": {
      "types": "./dist/describe/index.d.ts",
      "import": "./dist/describe/index.js"
    },
    "./descriptor": {
      "types": "./dist/descriptor/index.d.ts",
      "import": "./dist/descriptor/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.2"
  }
}
